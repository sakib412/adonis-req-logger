{
  "name": "adonis-req-logger",
  "version": "0.2.0",
  "private": false,
  "type": "module",
  "description": "Request logging for AdonisJS — one structured, canonical log line per HTTP request, with per-request Lucid query stats",
  "license": "MIT",
  "keywords": [
    "adonisjs",
    "adonis",
    "logging",
    "request-logger",
    "http-logger",
    "pino"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "files": [
    "build"
  ],
  "exports": {
    ".": "./build/index.js",
    "./req_logger_provider": "./build/providers/req_logger_provider.js",
    "./req_logger_middleware": "./build/src/req_logger_middleware.js",
    "./pretty": "./build/pretty.js",
    "./types": "./build/src/types.js"
  },
  "scripts": {
    "clean": "node -e \"fs.rmSync('build', { recursive: true, force: true })\"",
    "copy:stubs": "node -e \"fs.cpSync('stubs', 'build/stubs', { recursive: true, filter: (src) => !src.endsWith('.ts') })\"",
    "build": "npm run clean && tsc && npm run copy:stubs",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write ."
  },
  "peerDependencies": {
    "@adonisjs/core": "^7.0.0",
    "@adonisjs/lucid": ">=21.0.0",
    "pino-pretty": ">=11.0.0"
  },
  "peerDependenciesMeta": {
    "@adonisjs/lucid": {
      "optional": true
    },
    "pino-pretty": {
      "optional": true
    }
  },
  "devDependencies": {
    "@adonisjs/core": "^7.3.3",
    "@adonisjs/prettier-config": "^1.5.0",
    "@adonisjs/tsconfig": "^2.0.0",
    "@types/node": "~25.9.1",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.9.4",
    "typescript": "~6.0.3"
  },
  "prettier": "@adonisjs/prettier-config"
}
