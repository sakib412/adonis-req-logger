{
  "name": "adonis-req-logger",
  "version": "5.1.0",
  "private": false,
  "description": "Request logging for AdonisJS v5 — one structured, canonical log line per HTTP request, with per-request Lucid query stats",
  "license": "MIT",
  "author": "Najmus Sakib <nazmusakib412@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sakib412/adonis-req-logger.git",
    "directory": "packages/adonis-req-logger"
  },
  "homepage": "https://github.com/sakib412/adonis-req-logger/tree/v5.x/packages/adonis-req-logger#readme",
  "bugs": "https://github.com/sakib412/adonis-req-logger/issues",
  "keywords": [
    "adonisjs",
    "adonis",
    "adonis5",
    "logging",
    "request-logger",
    "http-logger",
    "pino"
  ],
  "engines": {
    "node": ">=14.15.4"
  },
  "main": "./build/providers/ReqLoggerProvider.js",
  "types": "./build/adonis-typings/index.d.ts",
  "files": [
    "build/adonis-typings",
    "build/providers",
    "build/src",
    "build/templates",
    "build/instructions.md"
  ],
  "publishConfig": {
    "tag": "adonis5"
  },
  "scripts": {
    "clean": "node -e \"fs.rmSync('build', { recursive: true, force: true })\"",
    "copy:templates": "node -e \"fs.cpSync('templates', 'build/templates', { recursive: true }); fs.copyFileSync('instructions.md', 'build/instructions.md')\"",
    "build": "npm run clean && tsc && npm run copy:templates",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write ."
  },
  "dependencies": {
    "on-finished": "^2.4.1"
  },
  "peerDependencies": {
    "@adonisjs/core": "^5.9.0",
    "@adonisjs/lucid": "^18.0.0"
  },
  "peerDependenciesMeta": {
    "@adonisjs/lucid": {
      "optional": true
    }
  },
  "devDependencies": {
    "@adonisjs/core": "5.9.0",
    "@adonisjs/lucid": "18.4.2",
    "@adonisjs/prettier-config": "^1.5.0",
    "@types/node": "^14.18.63",
    "@types/on-finished": "^2.3.4",
    "prettier": "^3.9.4",
    "typescript": "~4.9.5"
  },
  "prettier": "@adonisjs/prettier-config",
  "adonisjs": {
    "instructionsMd": "./build/instructions.md",
    "types": "adonis-req-logger",
    "providers": [
      "adonis-req-logger"
    ],
    "templates": {
      "basePath": "./build/templates",
      "config": [
        {
          "src": "config.txt",
          "dest": "req_logger"
        }
      ]
    }
  }
}
