{
  "compilerOptions": {
    "target": "ES2019",
    "lib": ["ES2019"],
    "module": "commonjs",
    "moduleResolution": "node",
    "rootDir": "./",
    "outDir": "./build",
    "declaration": true,
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "types": ["node", "on-finished", "@adonisjs/core", "@adonisjs/lucid"]
  },
  "include": ["adonis-typings/**/*.ts", "providers/**/*.ts", "src/**/*.ts"],
  "exclude": ["node_modules", "build"]
}
